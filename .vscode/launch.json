{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ThreatLens: Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/extension"],
      "outFiles": ["${workspaceFolder}/packages/extension/out/**/*.js"],
      "preLaunchTask": "threatlens: compile extension"
    }
  ]
}
